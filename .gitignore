# ------------------------------
# Monorepo root ignores
# ------------------------------

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
.history/

# Env and secrets
.env
.env.*
!.env.example
*.pem

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------
# Node / Next.js (apps/web)
# ------------------------------
**/node_modules/
**/.pnp
**/.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

**/.next/
**/out/
**/build/
**/dist/
**/coverage/
**/*.tsbuildinfo
**/next-env.d.ts
**/.vercel/

# ------------------------------
# Python / FastAPI (apps/api)
# ------------------------------
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.python-version

# Virtual environments (common names)
**/.venv/
**/venv/
**/env/
**/.env/

# Test/cache/tooling
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.coverage
**/.coverage.*
**/htmlcov/
**/.tox/
**/.nox/
**/.hypothesis/

# FastAPI/static build artifacts
**/.fastapi/

# ------------------------------
# Databases/local runtime files
# ------------------------------
*.sqlite3
*.db

